# Copy to env.yaml and fill in your values, then run: ./deploy.sh
# env.yaml is gitignored — never commit real secrets.

SUPABASE_URL: "https://your-project.supabase.co"
SUPABASE_KEY: "your-supabase-anon-key"
GEMINI_API_KEY: "your-gemini-api-key"
SECRET_KEY: "generate-a-long-random-secret-for-sessions"
