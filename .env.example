# Local development — copy to server/.env

# Supabase (Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key # Required for CRM permissions

# AI & Processing
GEMINI_API_KEY=your-gemini-api-key

# Server Config & Security
PORT=3001
SECRET_KEY=generate-a-long-random-secret-for-sessions
JWT_SECRET=hrm-secret-key-fallback

# Frontend URLs & CORS (Important for deployment)
PUBLIC_APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_ONBOARDING_URL=http://localhost:3000
DIET_BUDDY_URL=https://dietbuddy.yourdomain.com
CRM_WS_CORS_ORIGINS=http://localhost:5173

# Third-party Integrations
# Zernio — Facebook page posting + CRM inbox replies
ZERNIO_API_KEY=your-zernio-api-key
ZERNIO_FACEBOOK_ACCOUNT_ID=your-zernio-facebook-account-id
ZERNIO_BASE_URL=https://zernio.com/api

# Legacy fallback — text-only posts if Zernio not set
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Biometric / Attendance
BIOMETRIC_API_KEY=zkteco-secret-key-123

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
